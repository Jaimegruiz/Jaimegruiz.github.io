---
import '../styles/global.css';
import { site } from '../data/site-data';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = `${site.name} | Taller mecánico en ${site.city}`,
  description = site.description,
  canonicalUrl = site.canonicalUrl,
} = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  name: site.name,
  description: site.description,
  url: site.canonicalUrl,
  telephone: site.phone.href,
  email: `mailto:${site.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.city,
    addressRegion: site.region,
    addressCountry: site.country ?? 'ES',
  },
  // TODO: Añadir dirección exacta (calle, CP) cuando esté disponible
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '13:30',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '15:30',
      closes: '18:00',
    },
  ],
  sameAs: [`https://wa.me/${site.mobile.href.replace('https://wa.me/', '')}`],
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:locale"      content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: AutoRepair schema -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>

    <!-- Acceso directo para lectores de pantalla -->
    <a class="skip-to-content" href="#main-content">Saltar al contenido principal</a>

    <slot />

  </body>
</html>
