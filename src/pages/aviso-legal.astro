---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Aviso Legal | Talleres El Corcho"
  description="Aviso legal de Talleres El Corcho, taller mecánico en Sanlúcar de Barrameda."
>
  <Header />
  <main id="main-content" class="pt-nav min-h-screen">
    <div class="max-w-3xl mx-auto px-5 py-16">
      <h1 class="text-3xl font-extrabold text-slate-800 mb-8">Aviso Legal</h1>

      <section class="prose prose-slate max-w-none">

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">1. Datos identificativos del titular</h2>
        <!-- TODO: Rellenar razón social, NIF/CIF, domicilio social e inscripción registral -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar por el titular del negocio.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">2. Condiciones de uso</h2>
        <!-- TODO: Términos y condiciones de uso del sitio web -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">3. Propiedad intelectual</h2>
        <!-- TODO: Derechos sobre contenido, imágenes, marca y logotipos -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">4. Responsabilidad</h2>
        <!-- TODO: Limitación de responsabilidad por el uso del sitio -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">5. Legislación aplicable</h2>
        <!-- TODO: Jurisdicción española, LSSI-CE, RGPD -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

      </section>

      <div class="mt-12 pt-8 border-t border-slate-200">
        <a href="/" class="text-sm text-accent hover:text-accent-hover font-medium transition-colors">
          ← Volver al inicio
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
