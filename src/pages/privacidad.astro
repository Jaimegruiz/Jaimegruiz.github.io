---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Política de Privacidad | Talleres El Corcho"
  description="Política de privacidad de Talleres El Corcho, taller mecánico en Sanlúcar de Barrameda."
>
  <Header />
  <main id="main-content" class="pt-nav min-h-screen">
    <div class="max-w-3xl mx-auto px-5 py-16">
      <h1 class="text-3xl font-extrabold text-slate-800 mb-8">Política de Privacidad</h1>

      <section class="prose prose-slate max-w-none">

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">1. Responsable del tratamiento</h2>
        <!-- TODO: Nombre, NIF, dirección y contacto del responsable -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">2. Finalidad del tratamiento</h2>
        <!-- TODO: Explicar para qué se usan los datos recogidos -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">3. Legitimación</h2>
        <!-- TODO: Base legal del tratamiento (consentimiento, contrato, interés legítimo…) -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">4. Derechos del interesado</h2>
        <!-- TODO: Acceso, rectificación, supresión, portabilidad, oposición, limitación -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">5. Conservación de datos</h2>
        <!-- TODO: Plazo de conservación según finalidad -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

        <h2 class="text-xl font-bold text-slate-700 mt-8 mb-3">6. Transferencias internacionales</h2>
        <!-- TODO: Si se transfieren datos a terceros países, indicarlo aquí -->
        <p class="text-slate-500 italic text-sm">Pendiente de completar.</p>

      </section>

      <div class="mt-12 pt-8 border-t border-slate-200">
        <a href="/" class="text-sm text-accent hover:text-accent-hover font-medium transition-colors">
          ← Volver al inicio
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
