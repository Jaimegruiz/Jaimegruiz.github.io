---
import { site } from '../data/site-data';
---
<footer class="bg-dark-2 text-slate-300 pt-14 pb-8">
  <div class="max-w-[1200px] mx-auto px-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 desk:grid-cols-[1.6fr_1fr_1fr] gap-10 mb-12">

      <!-- Marca / Descripción -->
      <div>
        <span class="block text-lg font-bold text-white mb-3">{site.name}</span>
        <img
          src="/images/logo-footer.png"
          alt="Euro Repar Car Service"
          class="h-16 w-auto mb-4"
          height="64"
          loading="lazy"
        />
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          Taller mecánico familiar en {site.city} con más de 25 años de experiencia.
          Tu vehículo, en las mejores manos.
        </p>
      </div>

      <!-- Navegación -->
      <nav aria-label="Navegación pie de página">
        <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Navegación</h4>
        <ul class="flex flex-col gap-2.5">
          {site.nav.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm text-slate-300 hover:text-white transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contacto rápido -->
      <div>
        <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Contacto rápido</h4>
        <ul class="flex flex-col gap-2.5">
          <li>
            <a href={site.phone.href} class="text-sm text-slate-300 hover:text-white transition-colors">{site.phone.display}</a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="text-sm text-slate-300 hover:text-white transition-colors break-all">{site.email}</a>
          </li>
          <li>
            <a
              href={site.bookingUrl}
              class="text-sm text-accent hover:text-accent-hover transition-colors font-medium"
              target="_blank"
              rel="noopener noreferrer"
            >Solicitar cita online</a>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500">
      <p>
        &copy; <span id="footer-year">2026</span> {site.name} &middot; {site.city}, {site.region}
      </p>
      <nav aria-label="Legal" class="flex gap-5">
        <a href="/aviso-legal" class="hover:text-slate-300 transition-colors">Aviso Legal</a>
        <a href="/privacidad"  class="hover:text-slate-300 transition-colors">Privacidad</a>
        <a href="/cookies"     class="hover:text-slate-300 transition-colors">Cookies</a>
      </nav>
      <p class="text-slate-600">Taller mecánico familiar con más de 25 años de experiencia</p>
    </div>

  </div>
</footer>

<script>
  const yearEl = document.getElementById('footer-year');
  if (yearEl) {
    yearEl.textContent = String(new Date().getFullYear());
  }
</script>
