---
import { site } from '../data/site-data';
---
<section id="inicio" class="hero relative bg-dark-3 text-white min-h-[100svh] flex items-center pt-nav" aria-labelledby="hero-title">

  <!-- Decoración de fondo -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="hero-bg-dots"></div>
    <div class="hero-bg-glow"></div>
  </div>

  <div class="max-w-[1200px] mx-auto px-5 py-20 w-full relative z-10">
    <div class="flex flex-col gap-10">

      <!-- Badge Euro Repar -->
      <div>
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent/10 border border-accent/25 text-accent text-sm font-semibold">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Euro Repar Car Service
        </span>
      </div>

      <!-- Título principal -->
      <div>
        <h1 id="hero-title" class="text-[clamp(2.25rem,5.5vw,4rem)] font-extrabold leading-[1.1] tracking-tight">
          <span class="block text-slate-200">Tu taller de confianza en</span>
          <span class="block text-accent">{site.city}</span>
        </h1>

        <p class="mt-5 text-lg text-slate-300 max-w-xl leading-relaxed">
          Más de 25 años cuidando de tu vehículo con rapidez, calidad y trato cercano.
        </p>
      </div>

      <!-- Botones de acción -->
      <div class="flex flex-wrap gap-3">

        <!-- Solicitar cita -->
        <a
          href={site.bookingUrl}
          class="inline-flex items-center gap-2 px-5 py-3 bg-accent hover:bg-accent-hover text-white font-semibold rounded-md shadow-accent hover:shadow-accent-lg transition-all min-h-[48px] hover:-translate-y-0.5"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Solicitar cita
        </a>

        <!-- Llamar -->
        <a
          href={site.phone.href}
          class="inline-flex items-center gap-2 px-5 py-3 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold rounded-md transition-all min-h-[48px] hover:-translate-y-0.5 backdrop-blur-sm"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.91-1.84a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Llamar ahora
        </a>

        <!-- WhatsApp -->
        <a
          href={site.mobile.href}
          class="inline-flex items-center gap-2 px-5 py-3 bg-wa hover:bg-wa-hover text-white font-semibold rounded-md shadow-wa transition-all min-h-[48px] hover:-translate-y-0.5"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Contactar por WhatsApp al ${site.mobile.display}`}
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          WhatsApp
        </a>
      </div>

      <!-- Stats destacados -->
      <div class="flex items-center gap-0 mt-4" aria-label="Datos destacados del taller">
        {site.stats.map((stat, i) => (
          <>
            <div class="flex flex-col items-center px-5 first:pl-0">
              <span class="text-3xl font-extrabold text-accent leading-none">{stat.number}</span>
              <span class="text-xs text-slate-400 text-center mt-1 leading-tight whitespace-pre-line">{stat.label}</span>
            </div>
            {i < site.stats.length - 1 && (
              <div class="w-px h-10 bg-white/15" aria-hidden="true"></div>
            )}
          </>
        ))}
      </div>

    </div>
  </div>
</section>
