---
import { site } from '../data/site-data';
import MapConsent from './MapConsent.astro';
---
<section id="contacto" class="py-20 bg-dark-3 text-white" aria-labelledby="contacto-title">
  <div class="max-w-[1200px] mx-auto px-5">

    <header class="text-center mb-14">
      <h2 id="contacto-title" class="section-title text-slate-100">Contacto</h2>
      <p class="mt-4 text-lg text-slate-400">¡Contáctenos sin compromiso!</p>
    </header>

    <div class="flex flex-col desk:flex-row gap-10 desk:gap-12">

      <!-- Datos de contacto -->
      <div class="flex-1">

        <ul class="flex flex-col gap-5" aria-label="Datos de contacto">

          <!-- Teléfono -->
          <li class="flex items-center gap-4">
            <span class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-accent/15 text-accent" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.91-1.84a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            <div>
              <span class="block text-xs text-slate-400 mb-0.5">Teléfono</span>
              <a href={site.phone.href} class="text-slate-200 hover:text-accent transition-colors font-medium">{site.phone.display}</a>
            </div>
          </li>

          <!-- Móvil / WhatsApp -->
          <li class="flex items-center gap-4">
            <span class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-wa/15 text-wa" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
            </span>
            <div>
              <span class="block text-xs text-slate-400 mb-0.5">Móvil / WhatsApp</span>
              <a href={site.mobile.href} class="text-slate-200 hover:text-wa transition-colors font-medium" target="_blank" rel="noopener noreferrer">{site.mobile.display}</a>
            </div>
          </li>

          <!-- Email -->
          <li class="flex items-center gap-4">
            <span class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-accent/15 text-accent" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <div>
              <span class="block text-xs text-slate-400 mb-0.5">Email</span>
              <a href={`mailto:${site.email}`} class="text-slate-200 hover:text-accent transition-colors font-medium">{site.email}</a>
            </div>
          </li>

          <!-- Fax -->
          <li class="flex items-center gap-4">
            <span class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-white/10 text-slate-400" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 17 13 17 11 20 9 17 2 17 2 3 22 3 22 17"/>
                <line x1="7" y1="10" x2="7" y2="10"/>
                <line x1="11" y1="10" x2="11" y2="10"/>
                <line x1="15" y1="10" x2="15" y2="10"/>
              </svg>
            </span>
            <div>
              <span class="block text-xs text-slate-400 mb-0.5">Fax</span>
              <span class="text-slate-200 font-medium">{site.fax}</span>
            </div>
          </li>

          <!-- Ubicación -->
          <li class="flex items-center gap-4">
            <span class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-accent/15 text-accent" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <div>
              <span class="block text-xs text-slate-400 mb-0.5">Ubicación</span>
              <span class="text-slate-200 font-medium">{site.city}, {site.region}</span>
            </div>
          </li>

        </ul>

        <!-- Botones de acción -->
        <div class="flex flex-wrap gap-3 mt-8">
          <a
            href={site.phone.href}
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent hover:bg-accent-hover text-white text-sm font-semibold rounded-md transition-colors min-h-[44px]"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.91-1.84a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Llamar ahora
          </a>

          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-white/10 hover:bg-white/20 border border-white/20 text-white text-sm font-semibold rounded-md transition-colors min-h-[44px]"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Enviar email
          </a>

          <a
            href={site.mobile.href}
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-wa hover:bg-wa-hover text-white text-sm font-semibold rounded-md transition-colors min-h-[44px]"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Contactar por WhatsApp"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            WhatsApp
          </a>

          <a
            href={site.bookingUrl}
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-slate-700 hover:bg-slate-600 border border-slate-600 text-white text-sm font-semibold rounded-md transition-colors min-h-[44px]"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Solicitar una cita
          </a>
        </div>

      </div>

      <!-- Mapa bajo demanda -->
      <div class="w-full desk:w-[480px] shrink-0">
        <MapConsent />
      </div>

    </div>

  </div>
</section>
