---
import { site } from '../data/site-data';
---
<div class="contacto-mapa w-full" data-maps-src={site.mapsEmbedSrc}>

  <!-- Placeholder visible hasta que el usuario pulsa "Ver mapa" -->
  <div id="map-placeholder" class="flex flex-col items-center justify-center gap-5 p-8 bg-dark-2 border border-white/10 rounded-xl aspect-[4/3] sm:aspect-video text-center">
    <div class="text-slate-400" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
    </div>
    <div>
      <p class="text-slate-300 font-semibold text-sm mb-1">Sanlúcar de Barrameda, Cádiz</p>
      <p class="text-slate-500 text-xs leading-relaxed max-w-xs mx-auto">
        Para ver el mapa se cargará contenido externo de Google Maps.
      </p>
    </div>
    <button
      id="map-load-btn"
      class="flex items-center gap-2 px-5 py-2.5 bg-accent hover:bg-accent-hover text-white text-sm font-semibold rounded-md transition-colors min-h-[44px]"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      Ver mapa
    </button>
  </div>

  <!-- Contenedor del iframe (oculto hasta consentimiento) -->
  <div id="map-frame-container" class="hidden aspect-[4/3] sm:aspect-video w-full rounded-xl overflow-hidden"></div>

</div>

<script>
  const wrapper     = document.querySelector<HTMLElement>('.contacto-mapa');
  const placeholder = document.getElementById('map-placeholder');
  const frameContainer = document.getElementById('map-frame-container');
  const loadBtn     = document.getElementById('map-load-btn') as HTMLButtonElement | null;

  if (loadBtn && placeholder && frameContainer && wrapper) {
    loadBtn.addEventListener('click', () => {
      const src = wrapper.dataset.mapsSrc ?? '';

      const iframe = document.createElement('iframe');
      iframe.src                  = src;
      iframe.width                = '100%';
      iframe.height               = '100%';
      iframe.loading              = 'lazy';
      iframe.allowFullscreen      = true;
      iframe.referrerPolicy       = 'no-referrer-when-downgrade';
      iframe.title                = 'Ubicación de Talleres El Corcho en Google Maps';
      iframe.setAttribute('aria-label', 'Mapa de Google Maps mostrando la ubicación de Talleres El Corcho en Sanlúcar de Barrameda');
      iframe.style.border         = '0';
      iframe.style.width          = '100%';
      iframe.style.height         = '100%';

      frameContainer.appendChild(iframe);
      placeholder.classList.add('hidden');
      frameContainer.classList.remove('hidden');
    });
  }
</script>
